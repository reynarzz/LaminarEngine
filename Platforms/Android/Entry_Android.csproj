<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0-android</TargetFramework>
    <SupportedOSPlatformVersion>23</SupportedOSPlatformVersion>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationId>com.reynarzz.company</ApplicationId>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
	<RuntimeIdentifiers>android-arm;android-arm64</RuntimeIdentifiers>
	<DefineConstants>ANDROID;MOBILE;$(DefineConstants)</DefineConstants>
	<AndroidFastDeploymentEnabled>false</AndroidFastDeploymentEnabled>
	<MinSdkVersion>23</MinSdkVersion>
	<TargetSdkVersion>34</TargetSdkVersion>
	<CompileSdkVersion>34</CompileSdkVersion>
	<UseLatestAndroidPlatformSdk>true</UseLatestAndroidPlatformSdk>
	<GameDataOutDir>$(MSBuildProjectDirectory)/Assets/</GameDataOutDir>
	  
	  <!--
      Enables trim analyzers and full trimming during Release mode.
      To learn more, see: https://learn.microsoft.com/dotnet/core/deploying/trimming/trimming-options#trimming-granularity
    -->
    <TrimMode>full</TrimMode>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
  </PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)' == 'Debug'">
		<EmbedAssembliesIntoApk>true</EmbedAssembliesIntoApk>
	</PropertyGroup>
	
	<ItemGroup>
		<ProjectReference Include="..\..\Engine\Engine.csproj" />
        <ProjectReference Include="..\..\Game\Game.csproj" />
  </ItemGroup>

	<ItemGroup>
		<PackageReference Include="Xamarin.Google.Android.Play.Asset.Delivery" Version="2.3.0.4" />
		<PackageReference Include="Xamarin.GooglePlayServices.Base" Version="118.9.0" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Assets\" />
	</ItemGroup>

	<PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-android'">
		<AddAssetsFolder>false</AddAssetsFolder>
	</PropertyGroup>

	<Target Name="AddAssets" AfterTargets="$(GameCookerBeforeBuildStage)" Condition="'$(AddAssetsFolder)' == 'true'">
		<ItemGroup>
			<AndroidAsset Include="Assets\**\*.*" />
		</ItemGroup>
	</Target>
	<ItemGroup>
		<AndroidNativeLibrary Include="..\..\Engine\Third\Soundflow\Src\Backends\MiniAudio\runtimes\android\armeabi-v7a\libminiaudio.so">
			<Abi>armeabi-v7a</Abi>
		</AndroidNativeLibrary>

		<AndroidNativeLibrary Include="..\..\Engine\Third\Soundflow\Src\Backends\MiniAudio\runtimes\android\arm64-v8a\libminiaudio.so">
			<Abi>arm64-v8a</Abi>
		</AndroidNativeLibrary>

		<AndroidNativeLibrary Include="..\..\Engine\Third\Soundflow\Src\Backends\MiniAudio\runtimes\android\x86_64\libminiaudio.so">
			<Abi>x86_64</Abi>
		</AndroidNativeLibrary>
	</ItemGroup>
</Project>