<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<SelfContained>true</SelfContained>
		<PublishSingleFile>true</PublishSingleFile>
		<InvariantGlobalization>true</InvariantGlobalization>
		<ApplicationIcon>Icon.ico</ApplicationIcon>
		<AssemblyName>$(AppName)</AssemblyName>
	</PropertyGroup>

	<PropertyGroup>
		<OutputType>Exe</OutputType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(OS)' == 'Windows_NT' AND '$(Configuration)' == 'Release'">
		<OutputType>WinExe</OutputType>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="Icon.ico" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Engine\Engine.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(ShipBuild)' == 'true'">
		<ProjectReference Include="$(LAM_APPLICATION_PROJECT_PATH)">
			<ReferenceOutputAssembly>true</ReferenceOutputAssembly>
			<Private>true</Private>
			<OutputItemType>Content</OutputItemType>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</ProjectReference>
	</ItemGroup>

	<ItemGroup>
		<TrimmerRootDescriptor Include="$(LAM_TRIMMER_LINK_RD_FILE)" />
	</ItemGroup>
</Project>
